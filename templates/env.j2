TZ={{ n8n_environment_variables_tz }}

GENERIC_TIMEZONE={{ n8n_environment_variables_tz }}

DB_POSTGRESDB_HOST={{ n8n_database_hostname }}
DB_POSTGRESDB_PORT={{ n8n_database_port }}
DB_POSTGRESDB_USER={{ n8n_database_username }}
DB_POSTGRESDB_PASSWORD={{ n8n_database_password }}
DB_POSTGRESDB_DATABASE={{ n8n_database_name }}

N8N_HOST={{ n8n_hostname }}
N8N_PATH={{ n8n_path_prefix }}
N8N_EDITOR_BASE_URL={{ n8n_scheme }}://{{ n8n_hostname }}{{ n8n_path_prefix }}

WEBHOOK_URL={{ n8n_scheme }}://{{ n8n_hostname }}{{ n8n_path_prefix }}

N8N_METRICS={{ n8n_environment_variables_n8n_metrics | to_json }}

{% if n8n_isolation_enabled %}
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false
EXTERNAL_FRONTEND_HOOKS_URLS=
N8N_DIAGNOSTICS_CONFIG_FRONTEND=
N8N_DIAGNOSTICS_CONFIG_BACKEND=
{% endif %}

