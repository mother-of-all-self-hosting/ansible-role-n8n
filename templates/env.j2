BASE_URL={{ fider_environment_variables_base_url }}
DATABASE_URL={{ fider_environment_variables_database_url }}
JWT_SECRET={{ fider_environment_variables_jwt_secret }}
EMAIL_NOREPLY={{ fider_environment_variables_email_noreply }}

{% if fider_email_smtp_enabled %}
EMAIL_SMTP_HOST={{ fider_environment_variables_email_smtp_host }}
EMAIL_SMTP_PORT={{ fider_environment_variables_email_smtp_port }}
EMAIL_SMTP_USERNAME={{ fider_environment_variables_email_smtp_username }}
EMAIL_SMTP_PASSWORD={{ fider_environment_variables_email_smtp_password }}
EMAIL_SMTP_ENABLE_STARTTLS={{ fider_environment_variables_email_smtp_enable_starttls }}
{% endif %}

{{ fider_environment_variables_additional_variables }}
