BASE_URL={{ n8n_environment_variables_base_url }}
DATABASE_URL={{ n8n_environment_variables_database_url }}
JWT_SECRET={{ n8n_environment_variables_jwt_secret }}
EMAIL_NOREPLY={{ n8n_environment_variables_email_noreply }}

{% if n8n_email_smtp_enabled %}
EMAIL_SMTP_HOST={{ n8n_environment_variables_email_smtp_host }}
EMAIL_SMTP_PORT={{ n8n_environment_variables_email_smtp_port }}
EMAIL_SMTP_USERNAME={{ n8n_environment_variables_email_smtp_username }}
EMAIL_SMTP_PASSWORD={{ n8n_environment_variables_email_smtp_password }}
EMAIL_SMTP_ENABLE_STARTTLS={{ n8n_environment_variables_email_smtp_enable_starttls }}
{% endif %}

{{ n8n_environment_variables_additional_variables }}
