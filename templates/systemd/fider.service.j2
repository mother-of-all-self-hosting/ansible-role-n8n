[Unit]
Description=Fider ({{ fider_identifier }})
{% for service in fider_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in fider_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}
DefaultDependencies=no

[Service]
Type=simple
Environment="HOME={{ devture_systemd_docker_base_systemd_unit_home_path }}"
ExecStartPre={{ devture_systemd_docker_base_host_command_sh }} -c '{{ fider_container_cleanup_command | trim | replace("\n", " ") }}'

ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} create \
      --rm \
      --name={{ fider_identifier }} \
      --log-driver=none \
      --user={{ fider_uid }}:{{ fider_gid }} \
      --cap-drop=ALL \
      --read-only \
      --network={{ fider_container_network }} \
      {% if fider_container_http_host_bind_port %}
      -p {{ fider_container_http_host_bind_port }}:{{ fider_container_http_port }} \
      {% endif %}
      --env-file={{ fider_base_path }}/env \
      --label-file={{ fider_base_path }}/labels \
      {% for volume in fider_container_additional_volumes %}
      --mount type={{ volume.type | default('bind' if '/' in volume.src else 'volume') }},src={{ volume.src }},dst={{ volume.dst }}{{ (',' + volume.options) if volume.options else '' }} \
      {% endfor %}
      {% for arg in fider_container_extra_arguments %}
      {{ arg }} \
      {% endfor %}
      {{ fider_container_image_self_build_name if fider_container_image_self_build else fider_container_image }}

{% for network in fider_container_additional_networks %}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} network connect {{ network }} {{ fider_identifier }}
{% endfor %}

ExecStart={{ devture_systemd_docker_base_host_command_docker }} start --attach {{ fider_identifier }}

ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ fider_identifier }} 2>/dev/null || true'
ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ fider_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ fider_identifier }}

[Install]
WantedBy=multi-user.target
