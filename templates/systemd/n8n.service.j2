[Unit]
Description=n8n ({{ n8n_identifier }})
{% for service in n8n_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in n8n_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}
DefaultDependencies=no

[Service]
Type=simple
Environment="HOME={{ devture_systemd_docker_base_systemd_unit_home_path }}"
ExecStartPre={{ devture_systemd_docker_base_host_command_sh }} -c '{{ n8n_container_cleanup_command | trim | replace("\n", " ") }}'

ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} create \
      --rm \
      --name={{ n8n_identifier }} \
      --log-driver=none \
      --user={{ n8n_uid }}:{{ n8n_gid }} \
      --cap-drop=ALL \
      --read-only \
      --network={{ n8n_container_network }} \
      {% if n8n_container_http_host_bind_port %}
      -p {{ n8n_container_http_host_bind_port }}:{{ n8n_container_http_port }} \
      {% endif %}
      --env-file={{ n8n_base_path }}/env \
      --label-file={{ n8n_base_path }}/labels \
      --mount type=bind,src={{ n8n_data_path }},dst=/home/node \
      {% if n8n_database_socket_enabled and n8n_database_socket_path_host != '' %}
      --mount type=bind,src={{ n8n_database_socket_path_host }},dst={{ n8n_database_socket_path_container }} \
      {% endif %}
      {% for volume in n8n_container_additional_volumes %}
      --mount type={{ volume.type | default('bind' if '/' in volume.src else 'volume') }},src={{ volume.src }},dst={{ volume.dst }}{{ (',' + volume.options) if volume.options | default('') else '' }} \
      {% endfor %}
      --tmpfs=/tmp:rw,noexec,nosuid,size={{ n8n_container_tmpfs_tmp_size }} \
      {% for arg in n8n_container_extra_arguments %}
      {{ arg }} \
      {% endfor %}
      {{ n8n_container_image }}

{% for network in n8n_container_additional_networks %}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} network connect {{ network }} {{ n8n_identifier }}
{% endfor %}

ExecStart={{ devture_systemd_docker_base_host_command_docker }} start --attach {{ n8n_identifier }}

ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ n8n_identifier }} 2>/dev/null || true'
ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ n8n_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ n8n_identifier }}

[Install]
WantedBy=multi-user.target
